<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Goal_Hours__c</fullName>
    <formula>IF(ISBLANK(Goal_Headcount__c) || Goal_Headcount__c = 0, 0,
        (VLOOKUP($ObjectType.WorkOrderLineItem.Fields.Goal_Minutes__c,
            $ObjectType.WorkOrderLineItem.Fields.WorkOrderId, Id) * Goal_Headcount__c) / 60)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Goal Hours</label>
    <precision>8</precision>
    <required>false</required>
    <scale>2</scale>
    <type>Number</type>
</CustomField>
